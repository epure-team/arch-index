#!/usr/bin/env bash
# arch-query — canned call-graph queries over an arch-index comment_db (SQLite).
# Usage: arch-query <db> <subcommand> [args]
#
# EDGE-KIND CONTRACT (PR-A). When the index is built by a ⊤-marking backend it carries a
# `calls.kind` ∈ {MUST, MAY_ENUMERATED, MAY_TOP} and a meta flag `callgraph_contract` in
# comment_db_meta. Semantics:
#   MUST           a uniquely-resolved static call            → trust a POSITIVE (reachability)
#   MAY_ENUMERATED a dynamic call bounded to a candidate set  → over-approx (used for unreachability)
#   MAY_TOP        an unresolvable/dynamic/reflective/FFI call → "could call anything"; never dropped
# `reaches` is an UNDER-approximation (MUST edges only): a positive path is must-reach ground truth.
# `unreachable` is the DUAL (over-approx): sound ONLY when the graph is ⊤-marked, so it REFUSES on a
# legacy/un-⊤-marked DB (where "no path" may merely hide a silently-dropped dynamic edge).
#
# Subcommands:
#   callers-of   <name>          who calls NAME (1 hop)
#   callees-of   <name>          what NAME calls (1 hop)
#   reachable-from <name>        transitive closure of callees from NAME
#   reaches      <from> <to>     MUST-only: does a definite call path exist? (positive = ground truth)
#   unreachable  <from> <to>     SOUND dual (requires ⊤-marking): REACHABLE | UNREACHABLE | UNKNOWN.
#                                UNREACHABLE iff TO is outside the (MUST∪MAY_ENUMERATED) closure of FROM
#                                AND no MAY_TOP edge is reachable from FROM (closed universe) → fails G2
#                                by construction. UNKNOWN if FROM can reach a MAY_TOP edge.
#   escapes      <from>          the MAY_TOP (⊤) edges reachable from FROM — the boundary forcing UNKNOWN
#   fan-in       [N]             top-N most-called functions (shared sinks / high-value targets)
#   exported                     all exported functions (external attack surface)
#   unresolved                   callees with no matching function row (legacy heuristic; superseded by
#                                MAY_TOP once the index is ⊤-marked)
#   find         <substr>        functions whose name matches substr
#   stats                        row counts (+ contract status)
#
# Code-health query pack (main-schema oriented; each cmd refuses on DBs lacking its columns):
#   large-files     [N=500]      modules with lines > N
#   large-functions [N=50]       functions with line_count > N
#   god-modules     [N=30]       modules (or files) with > N functions
#   missing-docs                 exposed functions with no intent
#   missing-mli                  modules without an .mli interface
#   unsafe-strings  [N=3]        string-typed fields repeated >= N times (newtype candidates)
#   duplicates                   same (name, signature) in > 1 module
#   type-search <field|-> [type] types matching field-name and/or field-type substrings
#   (see also: arch-body-compare — per-name body-hash comparison CLI)
#
# Curation layer (docs/curation-workflow.md; ledgers are human-curated via documented SQL):
#   low-coverage  [N=50]         functions whose LATEST coverage snapshot is < N%
#                                (populate via arch-coverage-load)
#   gardening     [open|log]     open (default): tasks with status != 'done'; log: work history
#   unsafe-params [unfixed|fixed|all]  curated newtype-debt ledger (default: unfixed)
#
#   metrics      [-o FILE]       flat JSON metrics object for the regression gate
#                                (pipe to arch-compare; see docs/adr/002-metrics-gate.md).
#                                Metrics whose source table/column is absent are omitted.
#
# Capability A — effects/mutation queries (requires effects tables from effects-schema-migration.sql):
#   mutators-of  <value-kind>    all functions that DIRECTLY mutate <value-kind>
#                                (e.g. GlobalVar, FieldAccess, HashTbl — see value_kinds table).
#                                Adds transitive mutators via the call graph (MUST∪MAY_ENUMERATED edges).
#   effects-of   <fn>            all mutations (direct + transitive) reachable from <fn>.
#                                Soundness label = weakest label in the closure.
#   pure-fns                     functions with no effects (direct or transitive, per the effects tables).
#
# Capability C — dead-code (requires ⊤-marked index for sound verdict):
#   dead-code    [--roots exported|<fn1,fn2,...>]
#                                Functions unreachable from all roots over MUST∪MAY_ENUMERATED∪MAY_TOP.
#                                Sound verdict when callgraph_contract is set; candidate-only otherwise.
#                                Default roots: all exported functions.
#
# Capability Layer B — attack-surface attributes (Phase 2):
# (requires capabilities-schema-migration.sql and arch-sidecar-load)
#   capabilities-of <component>  list all actions in component with reachability_class, actor_role,
#                                temporal_class, gating, value_touched, precondition.
#                                <component> is a path substring match (case-insensitive).
#   compose         <action>     forward 'sequence' and 'removes_guard' edges from <action>
#                                (the composition frontier of that action).
#   removes-guard   <guard>      all actions with gating matching <guard> and their
#                                incoming 'removes_guard' attack edges.
#   actor-paths     <value-kind> paths touching <value-kind> across ≥2 distinct actor roles.
#   prune           <A> <B>      P13 pruning signal: check if component A and component B share
#                                a 'shares_resource' attack edge.
set -euo pipefail
DB="${1:?usage: arch-query <db> <subcommand> [args]}"; shift
CMD="${1:?subcommand required}"; shift || true
[ -f "$DB" ] || { echo "arch-query: no such db: $DB" >&2; exit 2; }
q()    { sqlite3 -box "$DB" "$1"; }
qraw() { sqlite3 "$DB" "$1" 2>/dev/null || true; }

# --- edge-kind contract detection -----------------------------------------------------------------
kind_col=$(qraw "SELECT 1 FROM pragma_table_info('calls') WHERE name='kind' LIMIT 1;")
contract=$(qraw "SELECT value FROM comment_db_meta WHERE key='callgraph_contract' LIMIT 1;")
# `reaches` must-filter: MUST edges when the column exists, else treat every edge as MUST (legacy).
must_filter=""; [ -n "$kind_col" ] && must_filter="AND c.kind='MUST'"

RAW_A="${1-}"; RAW_B="${2-}"   # pre-sanitization values (numeric validation must see them)
A="${1-}"; A="${A//\'/}"       # sanitize (strip single quotes); null-safe under set -u
B="${2-}"; B="${B//\'/}"

# --- shared feature-detection helpers (health + curation query packs) ------------------------------
hq_has() { qraw "SELECT 1 FROM pragma_table_xinfo('$1') WHERE name='$2' LIMIT 1;"; }
hq_tbl() { qraw "SELECT 1 FROM sqlite_master WHERE type='table' AND name='$1' LIMIT 1;"; }
hq_refuse() { echo "arch-query: REFUSED — $CMD needs $1 (absent in this DB; flat NDJSON indexes lack it)." >&2; exit 3; }
hq_num() {  # validate threshold: default when empty, digits only.
  # Validates the RAW arg — quote-stripping could otherwise turn 5'0 into 50.
  local v="${1:-$2}"
  [[ "$v" =~ ^[0-9]+$ ]] || { echo "arch-query: $CMD threshold must be a non-negative integer" >&2; exit 2; }
  printf '%s' "$v"
}
hq_like() {  # escape LIKE wildcards; use with ESCAPE '\' (quotes already stripped)
  printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/%/\\%/g' -e 's/_/\\_/g'
}

require_contract() {
  if [ -z "$contract" ]; then
    echo "arch-query: REFUSED — this index is NOT ⊤-marked (no 'callgraph_contract' meta flag)." >&2
    echo "arch-query: '$CMD' would be UNSOUND: a 'no path' result may merely hide a silently-dropped" >&2
    echo "arch-query: dynamic/interface edge. Rebuild with a Tier-0+ backend that emits MAY_TOP edges." >&2
    exit 3
  fi
  # Contract flag ⇒ `kind` MUST be fully populated. A NULL/invalid kind is invisible to both the
  # closure filter and the ⊤ check (SQL 3-valued logic), which would let a real dropped edge read as a
  # false-sound UNREACHABLE. So refuse a malformed ⊤-marked index loudly — never trust the flag alone.
  if [ -z "$kind_col" ]; then
    echo "arch-query: REFUSED — 'callgraph_contract' is set but there is no 'kind' column: malformed ⊤-marked index." >&2
    exit 3
  fi
  local bad; bad=$(qraw "SELECT count(*) FROM calls WHERE kind IS NULL OR kind NOT IN ('MUST','MAY_ENUMERATED','MAY_TOP');")
  if [ "${bad:-0}" != "0" ]; then
    echo "arch-query: REFUSED — $bad call edge(s) have NULL/invalid kind, violating the ⊤-marking contract (every edge must be MUST | MAY_ENUMERATED | MAY_TOP). Rebuild the index." >&2
    exit 3
  fi
  return 0
}

case "$CMD" in
  callers-of)   q "SELECT DISTINCT caller_name, caller_file FROM calls WHERE callee_name='$A' ORDER BY 1;" ;;
  callees-of)   q "SELECT DISTINCT callee_name, callee_file FROM calls WHERE caller_name='$A' ORDER BY 1;" ;;
  reachable-from)
    q "WITH RECURSIVE reach(n) AS (SELECT '$A' UNION SELECT c.callee_name FROM calls c JOIN reach r ON c.caller_name=r.n) SELECT n AS reachable FROM reach WHERE n<>'$A' ORDER BY 1;" ;;

  reaches)   # under-approximation: MUST edges only. A POSITIVE is must-reach ground truth.
    q "WITH RECURSIVE reach(n) AS (
         SELECT '$A'
         UNION SELECT c.callee_name FROM calls c JOIN reach r ON c.caller_name=r.n WHERE 1=1 $must_filter)
       SELECT CASE
         WHEN EXISTS(SELECT 1 FROM reach WHERE n='$B') THEN 'PATH EXISTS (must-reach): $A -> $B'
         ELSE 'no MUST path: $A -> $B  (NOT proof of unreachability — use \`unreachable\`)'
       END AS result;" ;;

  unreachable)   # over-approximation dual; SOUND only on a ⊤-marked index.
    require_contract
    q "WITH RECURSIVE reach_res(n) AS (
         SELECT '$A'
         UNION SELECT c.callee_name FROM calls c JOIN reach_res r ON c.caller_name=r.n
               WHERE c.kind IN ('MUST','MAY_ENUMERATED'))
       SELECT CASE
         WHEN EXISTS(SELECT 1 FROM reach_res WHERE n='$B')
           THEN 'REACHABLE (may-reach): $A -> $B'
         WHEN EXISTS(SELECT 1 FROM calls c WHERE c.caller_name IN (SELECT n FROM reach_res) AND (c.kind IS NULL OR c.kind NOT IN ('MUST','MAY_ENUMERATED')))
           THEN 'UNKNOWN: no resolved path $A -> $B, but $A reaches a non-resolved (MAY_TOP / NULL / unknown-kind) edge — could-call-anything; cannot rule out a path. Do NOT kill G2.'
         ELSE 'UNREACHABLE: no resolved path $A -> $B and no reachable MAY_TOP — sound; G2 fails by construction.'
       END AS verdict;" ;;

  escapes)   # the ⊤ frontier reachable from FROM (why unreachability is UNKNOWN past here).
    require_contract
    q "WITH RECURSIVE reach_res(n) AS (
         SELECT '$A'
         UNION SELECT c.callee_name FROM calls c JOIN reach_res r ON c.caller_name=r.n
               WHERE c.kind IN ('MUST','MAY_ENUMERATED'))
       SELECT DISTINCT c.caller_name AS escaping_fn, c.call_site, COALESCE(c.kind,'NULL') AS kind
       FROM calls c WHERE c.caller_name IN (SELECT n FROM reach_res) AND (c.kind IS NULL OR c.kind NOT IN ('MUST','MAY_ENUMERATED')) ORDER BY 1;" ;;

  fan-in)       q "SELECT callee_name, count(DISTINCT caller_name) AS callers FROM calls GROUP BY callee_name ORDER BY callers DESC LIMIT ${1:-25};" ;;
  exported)     q "SELECT name, file_path FROM functions WHERE exported=1 ORDER BY file_path, name;" ;;
  unresolved)   q "SELECT DISTINCT callee_name FROM calls WHERE callee_name NOT IN (SELECT name FROM functions) ORDER BY 1;" ;;
  find)         q "SELECT name, file_path, exported FROM functions WHERE name LIKE '%$A%' ORDER BY name;" ;;
  stats)
    echo "contract: ${contract:-<none — not ⊤-marked; 'unreachable' will refuse>}"
    q "SELECT (SELECT count(*) FROM functions) AS functions, (SELECT count(*) FROM functions WHERE exported=1) AS exported, (SELECT count(*) FROM calls) AS call_edges;"
    if [ -n "$kind_col" ]; then q "SELECT kind, count(*) AS edges FROM calls GROUP BY kind ORDER BY 2 DESC;"; fi
    # Show effects stats if the table exists
    eff_tbl=$(qraw "SELECT 1 FROM sqlite_master WHERE type='table' AND name='function_effects' LIMIT 1;")
    if [ -n "$eff_tbl" ]; then
      q "SELECT (SELECT count(*) FROM function_effects) AS effect_rows, (SELECT count(DISTINCT function_name) FROM function_effects) AS fns_with_effects, (SELECT count(DISTINCT value_kind) FROM function_effects) AS value_kinds_seen;"
    fi ;;

  # ── Capability A: effects/mutation queries ──────────────────────────────────

  mutators-of)
    # All functions that mutate value_kind A (direct), plus transitive mutators
    # via MUST∪MAY_ENUMERATED call edges.
    # Usage: arch-query <db> mutators-of <value-kind>
    eff_tbl=$(qraw "SELECT 1 FROM sqlite_master WHERE type='table' AND name='function_effects' LIMIT 1;")
    [ -n "$eff_tbl" ] || {
      echo "arch-query: mutators-of requires the effects tables. Run: sqlite3 <db> < effects-schema-migration.sql && arch-effects-load <db>" >&2
      exit 3
    }
    # Detect schema: flat (caller_name TEXT) vs main (caller_id INTEGER FK).
    caller_name_col=$(qraw "SELECT 1 FROM pragma_table_info('calls') WHERE name='caller_name' LIMIT 1;")
    if [ -n "$caller_name_col" ]; then
      # Flat callgraph DB schema (arch-load): caller_name + callee_name are TEXT columns.
      q "WITH RECURSIVE
           direct_mutators(fn) AS (
             SELECT DISTINCT function_name FROM function_effects WHERE value_kind='$A'
           ),
           transitive(fn) AS (
             SELECT fn FROM direct_mutators
             UNION
             SELECT c.caller_name
             FROM calls c
             JOIN transitive t ON c.callee_name = t.fn
             WHERE c.kind IN ('MUST','MAY_ENUMERATED')
           )
         SELECT DISTINCT
           t.fn AS function_name,
           COALESCE(fe.file_path, f.file_path) AS file_path,
           CASE WHEN dm.fn IS NOT NULL THEN 'direct' ELSE 'transitive' END AS how,
           COALESCE(fe.soundness, 'candidate') AS soundness
         FROM transitive t
         LEFT JOIN direct_mutators dm ON dm.fn = t.fn
         LEFT JOIN function_effects fe ON fe.function_name = t.fn AND fe.value_kind='$A'
         LEFT JOIN functions f ON f.name = t.fn
         ORDER BY how DESC, t.fn;"
    else
      # Main arch-index DB schema: caller_id FK, callee_name TEXT.
      q "WITH RECURSIVE
           direct_mutators(fn) AS (
             SELECT DISTINCT function_name FROM function_effects WHERE value_kind='$A'
           ),
           transitive(fn) AS (
             SELECT fn FROM direct_mutators
             UNION
             SELECT cf.name
             FROM calls c
             JOIN functions cf ON c.caller_id = cf.id
             JOIN transitive t ON c.callee_name = t.fn
             WHERE c.kind IS NULL OR c.kind IN ('MUST','MAY_ENUMERATED')
           )
         SELECT DISTINCT
           t.fn AS function_name,
           COALESCE(fe.file_path, m.path) AS file_path,
           CASE WHEN dm.fn IS NOT NULL THEN 'direct' ELSE 'transitive' END AS how,
           COALESCE(fe.soundness, 'candidate') AS soundness
         FROM transitive t
         LEFT JOIN direct_mutators dm ON dm.fn = t.fn
         LEFT JOIN function_effects fe ON fe.function_name = t.fn AND fe.value_kind='$A'
         LEFT JOIN functions f ON f.name = t.fn
         LEFT JOIN modules m ON f.module_id = m.id
         ORDER BY how DESC, t.fn;"
    fi ;;

  effects-of)
    # All mutations (direct + transitive) reachable from function A.
    # Usage: arch-query <db> effects-of <fn>
    eff_tbl=$(qraw "SELECT 1 FROM sqlite_master WHERE type='table' AND name='function_effects' LIMIT 1;")
    [ -n "$eff_tbl" ] || {
      echo "arch-query: effects-of requires the effects tables." >&2
      exit 3
    }
    caller_name_col2=$(qraw "SELECT 1 FROM pragma_table_info('calls') WHERE name='caller_name' LIMIT 1;")
    if [ -n "$caller_name_col2" ]; then
      # Flat schema
      q "WITH RECURSIVE
           reach(n) AS (
             SELECT '$A'
             UNION SELECT c.callee_name
             FROM calls c JOIN reach r ON c.caller_name=r.n
             WHERE c.kind IN ('MUST','MAY_ENUMERATED')
           )
         SELECT DISTINCT fe.value_kind, fe.function_name AS mutating_fn,
                         fe.file_path, fe.target, fe.soundness
         FROM function_effects fe
         WHERE fe.function_name IN (SELECT n FROM reach) AND fe.is_direct=1
         ORDER BY fe.value_kind, fe.function_name;"
    else
      # Main schema: caller_id FK
      q "WITH RECURSIVE
           reach(n) AS (
             SELECT '$A'
             UNION SELECT c.callee_name
             FROM calls c
             JOIN functions cf ON c.caller_id = cf.id
             JOIN reach r ON cf.name = r.n
             WHERE c.kind IS NULL OR c.kind IN ('MUST','MAY_ENUMERATED')
           )
         SELECT DISTINCT fe.value_kind, fe.function_name AS mutating_fn,
                         fe.file_path, fe.target, fe.soundness
         FROM function_effects fe
         WHERE fe.function_name IN (SELECT n FROM reach) AND fe.is_direct=1
         ORDER BY fe.value_kind, fe.function_name;"
    fi ;;

  pure-fns)
    # Functions provably free of effects, transitively.
    # SOUND definition (matches effects-schema-migration.sql v_pure_functions):
    # a function is pure iff its forward call closure reaches NO direct effect
    # AND no MAY_TOP (⊤) edge — i.e. it is NOT in the "impure" set, computed as
    # the backward closure over MUST∪MAY_ENUMERATED seeded by (a) functions with
    # a direct effect row and (b) functions with an outgoing MAY_TOP edge (which
    # could call anything, so purity cannot be certified). Fixes the earlier
    # unsound version that excluded only direct-effect functions.
    eff_tbl=$(qraw "SELECT 1 FROM sqlite_master WHERE type='table' AND name='function_effects' LIMIT 1;")
    [ -n "$eff_tbl" ] || {
      echo "arch-query: pure-fns requires the effects tables." >&2
      exit 3
    }
    mod_tbl=$(qraw "SELECT 1 FROM sqlite_master WHERE type='table' AND name='modules' LIMIT 1;")
    caller_name_col4=$(qraw "SELECT 1 FROM pragma_table_info('calls') WHERE name='caller_name' LIMIT 1;")
    if [ -n "$caller_name_col4" ]; then
      # Flat callgraph schema: caller_name TEXT in calls; file_path on functions.
      q "WITH RECURSIVE impure(fn) AS (
             SELECT DISTINCT function_name FROM function_effects WHERE is_direct=1
             UNION
             SELECT DISTINCT caller_name FROM calls WHERE kind='MAY_TOP'
             UNION
             SELECT c.caller_name
             FROM calls c JOIN impure i ON c.callee_name = i.fn
             WHERE c.kind IN ('MUST','MAY_ENUMERATED')
           )
         SELECT f.name, f.file_path
         FROM functions f
         WHERE f.name NOT IN (SELECT fn FROM impure)
           AND f.name NOT LIKE '%*TOP*%'
         ORDER BY f.file_path, f.name;"
    else
      # Main schema: caller_id FK, callee_name TEXT; path via modules table.
      q "WITH RECURSIVE impure(fn) AS (
             SELECT DISTINCT function_name FROM function_effects WHERE is_direct=1
             UNION
             SELECT DISTINCT cf.name
             FROM calls c JOIN functions cf ON c.caller_id = cf.id
             WHERE c.kind='MAY_TOP'
             UNION
             SELECT cf.name
             FROM calls c
             JOIN functions cf ON c.caller_id = cf.id
             JOIN impure i ON c.callee_name = i.fn
             WHERE c.kind IS NULL OR c.kind IN ('MUST','MAY_ENUMERATED')
           )
         SELECT f.name, m.path AS file_path
         FROM functions f
         LEFT JOIN modules m ON f.module_id = m.id
         WHERE f.name NOT IN (SELECT fn FROM impure)
           AND f.name NOT LIKE '%*TOP*%'
         ORDER BY m.path, f.name;"
    fi ;;

  # ── Capability C: dead-code / unreachable-from-roots ───────────────────────

  dead-code)
    # Usage: arch-query <db> dead-code [--roots exported|fn1,fn2,...]
    # Computes functions unreachable from all roots over MUST∪MAY_ENUMERATED∪MAY_TOP.
    # Sound verdict when callgraph_contract is set; candidate-only otherwise.
    roots_arg="${A:-exported}"
    soundness_label="candidate"
    [ -n "$contract" ] && soundness_label="sound"

    # Detect exported vs exposed column (flat DB uses 'exported'; main DB uses 'exposed').
    exported_col=$(qraw "SELECT 1 FROM pragma_table_info('functions') WHERE name='exported' LIMIT 1;")
    exposed_col=$(qraw "SELECT 1 FROM pragma_table_info('functions') WHERE name='exposed' LIMIT 1;")
    if [ -n "$exported_col" ]; then
      visibility_col="exported"
    elif [ -n "$exposed_col" ]; then
      visibility_col="exposed"
    else
      visibility_col="exported"  # fallback, will return empty
    fi

    if [ "$roots_arg" = "exported" ]; then
      # roots = all exported/exposed functions
      roots_clause="SELECT name FROM functions WHERE ${visibility_col}=1"
    else
      # roots = comma-separated list of function names
      # Convert fn1,fn2,... to SQL 'fn1','fn2',...
      roots_quoted=$(echo "$roots_arg" | sed "s/,/','/g; s/^/'/; s/$/'/")
      roots_clause="SELECT name FROM functions WHERE name IN ($roots_quoted)"
    fi

    mod_tbl2=$(qraw "SELECT 1 FROM sqlite_master WHERE type='table' AND name='modules' LIMIT 1;")
    caller_name_col3=$(qraw "SELECT 1 FROM pragma_table_info('calls') WHERE name='caller_name' LIMIT 1;")
    if [ -n "$mod_tbl2" ]; then
      fp_expr="m.path"
      join_clause="LEFT JOIN modules m ON f.module_id = m.id"
    else
      fp_expr="f.file_path"
      join_clause=""
    fi
    if [ -n "$caller_name_col3" ]; then
      # Flat schema: caller_name TEXT in calls
      edge_join="FROM calls c JOIN reach r ON c.caller_name=r.n"
    else
      # Main schema: join via caller_id FK
      edge_join="FROM calls c JOIN functions cf ON c.caller_id=cf.id JOIN reach r ON cf.name=r.n"
    fi
    q "WITH RECURSIVE
         roots(n) AS ($roots_clause),
         reach(n) AS (
           SELECT n FROM roots
           UNION SELECT c.callee_name $edge_join
         )
       SELECT
         f.name AS function_name,
         $fp_expr AS file_path,
         '$soundness_label' AS verdict_soundness
       FROM functions f
       $join_clause
       WHERE f.name NOT IN (SELECT n FROM reach)
         AND f.name NOT LIKE '%*TOP*%'
         AND f.name NOT IN (SELECT n FROM roots)
       ORDER BY $fp_expr, f.name;" ;;

  # ── Capability Layer B: attack-surface attribute queries ──────────────────

  capabilities-of)
    # List all actions in <component> with Phase-2 capability attributes.
    # Usage: arch-query <db> capabilities-of <component-path-substring>
    cap_tbl=$(qraw "SELECT 1 FROM sqlite_master WHERE type='table' AND name='function_effects' LIMIT 1;")
    [ -n "$cap_tbl" ] || {
      echo "arch-query: capabilities-of requires the effects tables. Run the migration first." >&2; exit 3; }
    rclass_col=$(qraw "SELECT 1 FROM pragma_table_info('function_effects') WHERE name='reachability_class' LIMIT 1;")
    [ -n "$rclass_col" ] || {
      echo "arch-query: capabilities-of requires Phase-2 columns. Run: sqlite3 <db> < capabilities-schema-migration.sql" >&2; exit 3; }
    q "SELECT DISTINCT
         fe.function_name,
         COALESCE(fe.reachability_class,'?')  AS rclass,
         COALESCE(fe.actor_role,'?')           AS actor_role,
         COALESCE(fe.temporal_class,'?')       AS temporal_class,
         COALESCE(fe.gating,'?')               AS gating,
         COALESCE(fe.value_touched,'[]')       AS value_touched,
         COALESCE(fe.precondition,'?')         AS precondition,
         fe.soundness
       FROM function_effects fe
       WHERE lower(COALESCE(fe.file_path,'')) LIKE '%$(echo "$A" | tr '[:upper:]' '[:lower:]')%'
          OR lower(fe.function_name) LIKE '%$(echo "$A" | tr '[:upper:]' '[:lower:]')%'
       ORDER BY fe.file_path, fe.function_name;" ;;

  compose)
    # Forward composition frontier of <action>: sequence and removes_guard edges.
    # Usage: arch-query <db> compose <action>
    ae_tbl=$(qraw "SELECT 1 FROM sqlite_master WHERE type='table' AND name='attack_edges' LIMIT 1;")
    [ -n "$ae_tbl" ] || {
      echo "arch-query: compose requires the attack_edges table. Run: sqlite3 <db> < capabilities-schema-migration.sql" >&2; exit 3; }
    q "SELECT ae.to_action, ae.edge_type, ae.evidence,
              COALESCE(fe.reachability_class,'?') AS to_rclass,
              COALESCE(fe.actor_role,'?') AS to_actor_role
       FROM attack_edges ae
       LEFT JOIN (
         SELECT function_name, reachability_class, actor_role
         FROM function_effects GROUP BY function_name
       ) fe ON ae.to_action = fe.function_name
       WHERE ae.from_action = '$A'
         AND ae.edge_type IN ('sequence','removes_guard')
       ORDER BY ae.edge_type, ae.to_action;" ;;

  removes-guard)
    # Actions with gating matching <guard> and their incoming removes_guard edges.
    # Usage: arch-query <db> removes-guard <guard-pattern>
    # <guard-pattern> is matched as a substring of the gating column.
    ae_tbl2=$(qraw "SELECT 1 FROM sqlite_master WHERE type='table' AND name='attack_edges' LIMIT 1;")
    rclass_col2=$(qraw "SELECT 1 FROM pragma_table_info('function_effects') WHERE name='gating' LIMIT 1;")
    ( [ -n "$ae_tbl2" ] && [ -n "$rclass_col2" ] ) || {
      echo "arch-query: removes-guard requires Phase-2 tables. Run the migration first." >&2; exit 3; }
    q "SELECT fe.function_name AS gated_action,
              fe.gating,
              ae.from_action   AS unlocker,
              ae.evidence
       FROM function_effects fe
       LEFT JOIN attack_edges ae
         ON ae.to_action = fe.function_name AND ae.edge_type = 'removes_guard'
       WHERE lower(COALESCE(fe.gating,'')) LIKE '%$(echo "$A" | tr '[:upper:]' '[:lower:]')%'
       ORDER BY fe.function_name, ae.from_action;" ;;

  actor-paths)
    # Paths touching <value-kind> across ≥2 distinct actor roles.
    # Usage: arch-query <db> actor-paths <value-kind>
    # Returns pairs (fn_a, fn_b) where fn_a and fn_b both touch value-kind
    # and have different actor_roles, linked by a call path.
    rclass_col3=$(qraw "SELECT 1 FROM pragma_table_info('function_effects') WHERE name='actor_role' LIMIT 1;")
    [ -n "$rclass_col3" ] || {
      echo "arch-query: actor-paths requires Phase-2 columns. Run: sqlite3 <db> < capabilities-schema-migration.sql" >&2; exit 3; }
    q "SELECT DISTINCT
         a.function_name  AS action_a,
         a.actor_role     AS actor_a,
         b.function_name  AS action_b,
         b.actor_role     AS actor_b,
         a.value_touched  AS value_touched_a,
         b.value_touched  AS value_touched_b
       FROM function_effects a
       JOIN function_effects b
         ON a.actor_role IS NOT NULL
        AND b.actor_role IS NOT NULL
        AND a.actor_role != b.actor_role
        AND a.function_name != b.function_name
       WHERE (
         a.value_kind = '$A' OR lower(COALESCE(a.value_touched,'')) LIKE '%\"kind\":\"$A\"%'
       )
       AND (
         b.value_kind = '$A' OR lower(COALESCE(b.value_touched,'')) LIKE '%\"kind\":\"$A\"%'
       )
       ORDER BY a.function_name, b.function_name;" ;;

  prune)
    # P13 pruning signal: check if component A and component B share a resource.
    # Usage: arch-query <db> prune <component-A> <component-B>
    # Returns any 'shares_resource' edges between functions in A and functions in B.
    ae_tbl3=$(qraw "SELECT 1 FROM sqlite_master WHERE type='table' AND name='attack_edges' LIMIT 1;")
    [ -n "$ae_tbl3" ] || {
      echo "arch-query: prune requires the attack_edges table. Run the migration first." >&2; exit 3; }
    result=$(qraw "SELECT count(*) FROM attack_edges ae
       JOIN function_effects fa ON ae.from_action = fa.function_name
       JOIN function_effects fb ON ae.to_action = fb.function_name
       WHERE ae.edge_type = 'shares_resource'
         AND (lower(COALESCE(fa.file_path,'')) LIKE '%$(echo "$A" | tr '[:upper:]' '[:lower:]')%'
              OR lower(fa.function_name) LIKE '%$(echo "$A" | tr '[:upper:]' '[:lower:]')%')
         AND (lower(COALESCE(fb.file_path,'')) LIKE '%$(echo "$B" | tr '[:upper:]' '[:lower:]')%'
              OR lower(fb.function_name) LIKE '%$(echo "$B" | tr '[:upper:]' '[:lower:]')%');")
    if [ "${result:-0}" = "0" ]; then
      echo "PRUNE: no shared resource found between '$A' and '$B' — safe to prune (P13 passes)"
    else
      echo "DO NOT PRUNE: $result shared_resource edge(s) between '$A' and '$B' — P13 signal"
      q "SELECT ae.from_action, ae.to_action, ae.evidence
         FROM attack_edges ae
         JOIN function_effects fa ON ae.from_action = fa.function_name
         JOIN function_effects fb ON ae.to_action = fb.function_name
         WHERE ae.edge_type = 'shares_resource'
           AND (lower(COALESCE(fa.file_path,'')) LIKE '%$(echo "$A" | tr '[:upper:]' '[:lower:]')%'
                OR lower(fa.function_name) LIKE '%$(echo "$A" | tr '[:upper:]' '[:lower:]')%')
           AND (lower(COALESCE(fb.file_path,'')) LIKE '%$(echo "$B" | tr '[:upper:]' '[:lower:]')%'
                OR lower(fb.function_name) LIKE '%$(echo "$B" | tr '[:upper:]' '[:lower:]')%');"
    fi ;;

  # ── Curation layer (specs/arch-gardening-queries.md) ───────────────────────
  # Read-only queries over the human-curated ledgers + coverage snapshots.
  # Ledger rows are inserted via documented SQL (docs/curation-workflow.md);
  # coverage rows via arch-coverage-load.

  low-coverage)   # functions whose LATEST coverage snapshot is below N% (default 50)
    N=$(hq_num "$RAW_A" 50)
    { [ -n "$(hq_has coverage recorded_at)" ] && [ -n "$(hq_has coverage percentage)" ] \
      && [ -n "$(hq_has functions module_id)" ] && [ -n "$(hq_has modules path)" ]; } \
      || hq_refuse "coverage columns + functions/modules join"
    q "SELECT m.path, f.name, c.percentage, c.covered_lines, c.total_lines
       FROM coverage c JOIN functions f ON c.function_id=f.id JOIN modules m ON f.module_id=m.id
       WHERE c.recorded_at = (SELECT MAX(recorded_at) FROM coverage c2 WHERE c2.function_id = c.function_id)
         AND c.percentage < $N
       ORDER BY c.percentage ASC, f.name, m.path;" ;;

  gardening)   # open (default): tasks not done; log: completed-work history
    sub="${A:-open}"
    { [ -n "$(hq_has gardening_tasks status)" ] && [ -n "$(hq_has gardening_tasks target_module_id)" ] \
      && [ -n "$(hq_has gardening_log date)" ]; } \
      || hq_refuse "gardening_tasks/gardening_log columns"
    case "$sub" in
      open)
        q "SELECT t.id, t.category, COALESCE(t.title,'') AS title, t.status,
                  t.github_issue, COALESCE(m.path,'') AS target
           FROM gardening_tasks t LEFT JOIN modules m ON t.target_module_id = m.id
           WHERE t.status != 'done' ORDER BY t.category, t.id;" ;;
      log)
        q "SELECT date, COALESCE(contributor,'') AS contributor, category, description,
                  pr_number, issue_number
           FROM gardening_log ORDER BY date DESC, id DESC;" ;;
      *) echo "usage: arch-query <db> gardening [open|log]" >&2; exit 2 ;;
    esac ;;

  unsafe-params)   # curated newtype-debt ledger (default: unfixed rows only)
    sub="${A:-unfixed}"
    { [ -n "$(hq_has unsafe_params fixed)" ] && [ -n "$(hq_has unsafe_params function_id)" ] \
      && [ -n "$(hq_has functions module_id)" ] && [ -n "$(hq_has modules path)" ]; } \
      || hq_refuse "unsafe_params columns + functions/modules join"
    base="SELECT m.path, f.name, u.param_name, u.current_type, COALESCE(u.target_type,'') AS target_type, u.github_issue%s
       FROM unsafe_params u JOIN functions f ON u.function_id=f.id JOIN modules m ON f.module_id=m.id%s
       ORDER BY m.path, f.name, u.param_name;"
    case "$sub" in
      unfixed) q "$(printf "$base" ""            " WHERE u.fixed = 0")" ;;
      fixed)   q "$(printf "$base" ""            " WHERE u.fixed = 1")" ;;
      all)     q "$(printf "$base" ", u.fixed"   "")" ;;
      *) echo "usage: arch-query <db> unsafe-params [unfixed|fixed|all]" >&2; exit 2 ;;
    esac ;;

  # ── Code-health query pack (specs/arch-health-queries.md) ──────────────────
  # Column-level feature detection: each command refuses (exit 3) when its
  # source columns are absent (flat NDJSON DBs lack most of them).

  large-files|large-functions|god-modules|missing-docs|missing-mli|unsafe-strings|duplicates|type-search)
    exp2=""  # exposed (main) | exported (flat)
    [ -n "$(hq_has functions exposed)" ] && exp2="exposed"
    [ -z "$exp2" ] && [ -n "$(hq_has functions exported)" ] && exp2="exported"
    case "$CMD" in
      large-files)
        N=$(hq_num "$RAW_A" 500)
        [ -n "$(hq_has modules lines)" ] || hq_refuse "modules.lines"
        q "SELECT path, lines FROM modules WHERE lines > $N ORDER BY lines DESC, path;" ;;
      large-functions)
        N=$(hq_num "$RAW_A" 50)
        [ -n "$(hq_has functions line_count)" ] || hq_refuse "functions.line_count"
        if [ -n "$(hq_has functions module_id)" ] && [ -n "$(hq_tbl modules)" ]; then
          q "SELECT f.name, m.path, f.line_count FROM functions f JOIN modules m ON f.module_id=m.id
             WHERE f.line_count > $N ORDER BY f.line_count DESC, f.name;"
        else
          q "SELECT name, line_count FROM functions WHERE line_count > $N ORDER BY line_count DESC, name;"
        fi ;;
      god-modules)
        N=$(hq_num "$RAW_A" 30)
        if [ -n "$(hq_has functions module_id)" ] && [ -n "$(hq_tbl modules)" ]; then
          q "SELECT m.path, count(*) AS functions FROM functions f JOIN modules m ON f.module_id=m.id
             GROUP BY m.id HAVING functions > $N ORDER BY functions DESC, m.path;"
        elif [ -n "$(hq_has functions file_path)" ]; then
          q "SELECT file_path, count(*) AS functions FROM functions GROUP BY file_path
             HAVING functions > $N ORDER BY functions DESC, file_path;"
        else hq_refuse "modules join or functions.file_path"; fi ;;
      missing-docs)
        [ -n "$exp2" ] || hq_refuse "an exposed/exported column"
        [ -n "$(hq_has functions intent)" ] || hq_refuse "functions.intent"
        if [ -n "$(hq_has functions module_id)" ] && [ -n "$(hq_tbl modules)" ]; then
          q "SELECT f.name, m.path FROM functions f JOIN modules m ON f.module_id=m.id
             WHERE f.$exp2=1 AND (f.intent IS NULL OR f.intent='') ORDER BY m.path, f.name;"
        else
          q "SELECT name FROM functions WHERE $exp2=1 AND (intent IS NULL OR intent='') ORDER BY name;"
        fi ;;
      missing-mli)
        [ -n "$(hq_has modules has_mli)" ] || hq_refuse "modules.has_mli"
        q "SELECT path FROM modules WHERE COALESCE(has_mli,0)=0 ORDER BY path;" ;;
      unsafe-strings)
        N=$(hq_num "$RAW_A" 3)
        { [ -n "$(hq_has type_fields field_name)" ] && [ -n "$(hq_has type_fields field_type)" ] \
          && [ -n "$(hq_has types module_id)" ] && [ -n "$(hq_has modules path)" ]; } \
          || hq_refuse "type_fields/types/modules columns"
        q "SELECT tf.field_name, count(*) AS occurrences,
                  GROUP_CONCAT(DISTINCT m.path || '.' || t.name ORDER BY m.path || '.' || t.name) AS in_types
           FROM type_fields tf JOIN types t ON tf.type_id=t.id JOIN modules m ON t.module_id=m.id
           WHERE tf.field_type='string'
           GROUP BY tf.field_name HAVING occurrences >= $N
           ORDER BY occurrences DESC, tf.field_name;" ;;
      duplicates)
        [ -n "$(hq_has functions signature)" ] || hq_refuse "functions.signature"
        { [ -n "$(hq_has functions module_id)" ] && [ -n "$(hq_tbl modules)" ]; } || hq_refuse "modules join"
        q "SELECT f.name, substr(f.signature,1,70) AS signature,
                  count(DISTINCT f.module_id) AS module_count,
                  GROUP_CONCAT(DISTINCT m.path ORDER BY m.path) AS modules
           FROM functions f JOIN modules m ON f.module_id=m.id
           WHERE f.signature IS NOT NULL AND f.signature <> ''
           GROUP BY f.name, f.signature HAVING module_count > 1
           ORDER BY module_count DESC, f.name;" ;;
      type-search)
        [ -n "$A" ] || { echo "usage: arch-query <db> type-search <field-substr|-> [type-substr]" >&2; exit 2; }
        if [ "$A" = "-" ] && [ -z "$B" ]; then
          echo "arch-query: type-search needs at least one real value" >&2; exit 2
        fi
        { [ -n "$(hq_has type_fields field_name)" ] && [ -n "$(hq_has type_fields field_type)" ] \
          && [ -n "$(hq_has types module_id)" ] && [ -n "$(hq_has modules path)" ]; } \
          || hq_refuse "type_fields/types/modules columns"
        where="1=1"
        [ "$A" != "-" ] && where="$where AND t.id IN (SELECT type_id FROM type_fields WHERE field_name LIKE '%$(hq_like "$A")%' ESCAPE '\\')"
        [ -n "$B" ] && where="$where AND t.id IN (SELECT type_id FROM type_fields WHERE field_type LIKE '%$(hq_like "$B")%' ESCAPE '\\')"
        q "SELECT m.path, t.name, GROUP_CONCAT(tf.field_name || ': ' || tf.field_type, ', ' ORDER BY tf.position, tf.field_name) AS fields
           FROM types t JOIN modules m ON t.module_id=m.id JOIN type_fields tf ON tf.type_id=t.id
           WHERE $where GROUP BY t.id ORDER BY m.path, t.name;" ;;
    esac ;;

  metrics)   # flat JSON metrics for the regression gate (specs/arch-metrics-gate.md).
    # FR-003: a metric whose source table/column is absent is OMITTED, never emitted as 0.
    fn_tbl=$(qraw "SELECT 1 FROM sqlite_master WHERE type='table' AND name='functions' LIMIT 1;")
    if [ -z "$fn_tbl" ]; then
      echo "arch-query: REFUSED — no 'functions' table in this DB; not an arch-index index." >&2
      exit 3
    fi
    out_file=""
    if [ "$A" = "-o" ]; then
      [ -n "$B" ] || { echo "usage: arch-query <db> metrics [-o FILE]" >&2; exit 2; }
      [ -z "${3-}" ] || { echo "usage: arch-query <db> metrics [-o FILE]" >&2; exit 2; }
      out_file="$B"
    elif [ -n "$A" ]; then
      echo "arch-query: metrics takes no argument except -o FILE" >&2; exit 2
    fi
    # feature detection (FR-002/FR-005). pragma_table_xinfo, NOT table_info:
    # generated columns (functions.line_count) are hidden from table_info.
    exp_col=""   # main schema: exposed; flat schema: exported
    [ -n "$(qraw "SELECT 1 FROM pragma_table_xinfo('functions') WHERE name='exposed' LIMIT 1;")" ] && exp_col="exposed"
    [ -z "$exp_col" ] && [ -n "$(qraw "SELECT 1 FROM pragma_table_xinfo('functions') WHERE name='exported' LIMIT 1;")" ] && exp_col="exported"
    cq_col=$(qraw "SELECT 1 FROM pragma_table_xinfo('functions') WHERE name='comment_quality_score' LIMIT 1;")
    lc_col=$(qraw "SELECT 1 FROM pragma_table_xinfo('functions') WHERE name='line_count' LIMIT 1;")
    mod_tbl=$(qraw "SELECT 1 FROM sqlite_master WHERE type='table' AND name='modules' LIMIT 1;")
    ml_col=""; [ -n "$mod_tbl" ] && ml_col=$(qraw "SELECT 1 FROM pragma_table_xinfo('modules') WHERE name='lines' LIMIT 1;")
    calls_tbl=$(qraw "SELECT 1 FROM sqlite_master WHERE type='table' AND name='calls' LIMIT 1;")
    # assemble json_object() args in lexicographic key order (FR-001)
    pairs=""
    addpair() { pairs="${pairs:+$pairs, }'$1', ($2)"; }
    [ -n "$calls_tbl" ] && addpair "call_edges" "SELECT count(*) FROM calls"
    if [ -n "$cq_col" ] && [ -n "$exp_col" ]; then
      addpair "doc_coverage_pct" "SELECT CASE WHEN (SELECT count(*) FROM functions WHERE $exp_col=1)=0 THEN 100.0
        ELSE ROUND(100.0 * (1.0 - CAST((SELECT count(*) FROM functions WHERE $exp_col=1 AND (comment_quality_score IS NULL OR comment_quality_score=0)) AS REAL)
                                  / (SELECT count(*) FROM functions WHERE $exp_col=1)), 1) END"
    fi
    [ -n "$exp_col" ] && addpair "exported_functions" "SELECT count(*) FROM functions WHERE $exp_col=1"
    [ -n "$ml_col" ] && addpair "large_files" "SELECT count(*) FROM modules WHERE lines > 500"
    [ -n "$lc_col" ] && addpair "large_functions" "SELECT count(*) FROM functions WHERE line_count > 50"
    [ -n "$calls_tbl" ] && [ -n "$kind_col" ] && addpair "may_top_edges" "SELECT count(*) FROM calls WHERE kind='MAY_TOP'"
    [ -n "$mod_tbl" ] && addpair "modules" "SELECT count(*) FROM modules"
    addpair "total_functions" "SELECT count(*) FROM functions"
    if [ -n "$cq_col" ] && [ -n "$exp_col" ]; then
      addpair "undocumented_exposed" "SELECT count(*) FROM functions WHERE $exp_col=1 AND (comment_quality_score IS NULL OR comment_quality_score=0)"
    fi
    if [ -n "$(qraw "SELECT json_object('probe', 1);")" ]; then
      json=$(sqlite3 "$DB" "SELECT json_object($pairs);")
    else
      # fallback for sqlite3 builds without JSON functions: hand-assemble
      json="{"; first=1
      # re-walk the same pairs string is fragile — recompute per metric
      emit() { v=$(qraw "$2"); [ -z "$v" ] && v=0
               [ $first -eq 1 ] && first=0 || json="$json, "
               json="$json\"$1\": $v"; }
      [ -n "$calls_tbl" ] && emit "call_edges" "SELECT count(*) FROM calls;"
      if [ -n "$cq_col" ] && [ -n "$exp_col" ]; then
        emit "doc_coverage_pct" "SELECT CASE WHEN (SELECT count(*) FROM functions WHERE $exp_col=1)=0 THEN 100.0
          ELSE ROUND(100.0 * (1.0 - CAST((SELECT count(*) FROM functions WHERE $exp_col=1 AND (comment_quality_score IS NULL OR comment_quality_score=0)) AS REAL)
                                    / (SELECT count(*) FROM functions WHERE $exp_col=1)), 1) END;"
      fi
      [ -n "$exp_col" ] && emit "exported_functions" "SELECT count(*) FROM functions WHERE $exp_col=1;"
      [ -n "$ml_col" ] && emit "large_files" "SELECT count(*) FROM modules WHERE lines > 500;"
      [ -n "$lc_col" ] && emit "large_functions" "SELECT count(*) FROM functions WHERE line_count > 50;"
      [ -n "$calls_tbl" ] && [ -n "$kind_col" ] && emit "may_top_edges" "SELECT count(*) FROM calls WHERE kind='MAY_TOP';"
      [ -n "$mod_tbl" ] && emit "modules" "SELECT count(*) FROM modules;"
      emit "total_functions" "SELECT count(*) FROM functions;"
      if [ -n "$cq_col" ] && [ -n "$exp_col" ]; then
        emit "undocumented_exposed" "SELECT count(*) FROM functions WHERE $exp_col=1 AND (comment_quality_score IS NULL OR comment_quality_score=0);"
      fi
      json="$json}"
    fi
    if [ -n "$out_file" ]; then
      if ! printf '%s\n' "$json" > "$out_file" 2>/dev/null; then
        echo "arch-query: cannot write to '$out_file'" >&2; exit 2
      fi
    else
      printf '%s\n' "$json"
    fi ;;

  *) echo "arch-query: unknown subcommand '$CMD'" >&2; exit 2 ;;
esac
