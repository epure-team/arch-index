    {
      "id": "step-3",
      "skill": "roster-qa",
      "inputs": ["briefs/arch-metrics-gate-qa-scope.md"],
      "outputs": ["briefs/arch-metrics-gate-qa.md"],
      "hook": false
    },
    {
      "id": "step-4",
      "skill": "roster-ship",
      "inputs": ["briefs/arch-metrics-gate-review.json", "briefs/arch-metrics-gate-qa.md"],
      "outputs": [],
      "hook": false
    }
  ],
  "quality_gates": {
    "build": "opam exec -- dune build",
